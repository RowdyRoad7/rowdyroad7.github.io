rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Delivery sign-off records captured by the DelRx module.
    match /deliveries/{docId} {
      // Any signed-in user may read / list the delivery log.
      allow read: if request.auth != null;

      // Signed-in users may create records. Each record must be stamped
      // with the creator's own uid and carry the core delivery fields.
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.address is string
        && request.resource.data.signature is string;

      // Records are an immutable proof-of-delivery audit trail:
      // no client-side edits or deletes.
      allow update, delete: if false;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
